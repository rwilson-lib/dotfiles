# vim: ft=muttrc:foldmethod=marker

# {{{ Icloud
IMAPAccount icloud
	Host imap.mail.me.com
	Port 993
	User ramus_wilson@icloud.com 
	PassCmd "pass show App/Icloud/ramus_wilson@icloud.com"
	SSLType IMAPS
	SSLVersions TLSv1.2
	AuthMechs PLAIN
	# CertificateFile /usr/local/etc/openssl/cert.pem

IMAPStore icloud-remote
	Account icloud

MaildirStore icloud-local
	Path ~/Mail/Icloud/
	Inbox ~/Mail/Icloud/Inbox/
	SubFolders Verbatim

Channel icloud
	Far :icloud-remote:
	Near :icloud-local:
# Include everything
	Patterns *
	Create Both
	Sync All
	Expunge Both
	SyncState *
# }}}

# {{{ Gmail 
IMAPAccount gmail
	Host imap.gmail.com
	Port 993
	User ramuswilson@gmail.com
	PassCmd "pass show App/Gmail/ramuswilson@gmail.com"
	SSLType IMAPS
	AuthMechs PLAIN
	# CertificateFile /usr/local/etc/openssl/cert.pem

IMAPStore gmail-remote
	Account gmail

MaildirStore gmail-local
	Path ~/Mail/Gmail/
	Inbox ~/Mail/Gmail/Inbox/
	SubFolders Verbatim

Channel gmail
	Far :gmail-remote:
	Near :gmail-local:
# Include everything
	# Patterns * ![Gmail]* "[Gmail]/Sent Mail" "[Gmail]/Starred" "[Gmail]/All Mail"
	Patterns * 
	Create Both
	Sync All
	Expunge Both
	SyncState *
# }}}

# {{{ Outlook 
IMAPAccount outlook
	Host outlook.office365.com
	Port 993
	User ramuswilson@outlook.com
	PassCmd "pass show App/Outlook/ramuswilson@outlook.com"
	SSLType IMAPS
	AuthMechs PLAIN
	# CertificateFile /usr/local/etc/openssl/cert.pem

IMAPStore outlook-remote
	Account outlook

MaildirStore outlook-local
	Path ~/Mail/Outlook/
	Inbox ~/Mail/Outlook/Inbox/
	SubFolders Verbatim

Channel outlook
	Far :outlook-remote:
	Near :outlook-local:
# Include everything
	Patterns *
	Create Both
	Sync All
	Expunge Both
	SyncState *

# }}}
